# Shared secret between the bot and relay service.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# Must also be set in config.yaml under meshcore.relay_token
RELAY_TOKEN=

# IP address or hostname of the MeshCore companion device
COMPANION_HOST=

# TCP port the companion listens on (default 4403)
COMPANION_PORT=4403
